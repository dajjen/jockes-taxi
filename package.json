{
  "name": "jockes-taxi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Statisk one-page-sajt för Jockes Taxi Gotland.",
  "scripts": {
    "test": "npm run test:html && npm run test:seo && npm run test:links",
    "test:html": "html-validate index.html",
    "test:seo": "node --test",
    "test:links": "linkinator . --config .linkinator.config.json",
    "serve": "npx --yes http-server -p 8799 -c-1 ."
  },
  "devDependencies": {
    "html-validate": "^9.7.1",
    "linkinator": "^6.1.2",
    "node-html-parser": "^7.0.1"
  }
}
